<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorSurface"
        app:title="@string/dashboard_title"
        app:titleTextColor="@color/colorTextPrimary"
        app:subtitle="@string/dashboard_subtitle"
        app:subtitleTextColor="@color/colorTextSecondary"
        app:navigationIconTint="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== CARD 1: Current Stream Config ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📡  Current Stream Config"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnRefreshConfig"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Refresh"
                        android:src="@android:drawable/ic_menu_rotate"
                        app:tint="@color/colorTextSecondary" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressConfig"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="@color/colorAccent"
                    android:visibility="gone" />

                <!-- Active URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Active URL:"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvActiveUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Loading..."
                    android:textColor="@color/colorTextPrimary"
                    android:textIsSelectable="true"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvActiveLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Label: —"
                    android:textColor="@color/colorStatusDefault"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvActiveUpdatedAt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Updated: —"
                    android:textColor="@color/colorStatusDefault"
                    android:textSize="12sp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/colorBorder" />

                <!-- Secondary URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secondary URL:"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSecondaryUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Not set"
                    android:textColor="@color/colorTextSecondary"
                    android:textIsSelectable="true"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvSecondaryLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Label: —"
                    android:textColor="@color/colorStatusDefault"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ===== CARD 2: Update Active Stream ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴  Update Active Stream"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etActiveLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="Stream label (e.g. Main HD)"
                    android:inputType="text"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorStatusDefault"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etActiveUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edit_text_background"
                    android:gravity="top|start"
                    android:hint="Paste .m3u8 URL"
                    android:inputType="textMultiLine|textUri"
                    android:minLines="3"
                    android:maxLines="5"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorStatusDefault"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnPasteActive"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/btn_outlined_dark"
                    android:text="📋  Paste from Clipboard"
                    android:textAllCaps="false"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnUpdateActive"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/btn_red_rounded"
                    android:text="🔄  Update Active URL"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ===== CARD 3: Update Secondary Stream ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔵  Update Backup Stream"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etSecondaryLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="Stream label (e.g. Backup SD)"
                    android:inputType="text"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorStatusDefault"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etSecondaryUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edit_text_background"
                    android:gravity="top|start"
                    android:hint="Paste .m3u8 URL"
                    android:inputType="textMultiLine|textUri"
                    android:minLines="3"
                    android:maxLines="5"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorStatusDefault"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnPasteSecondary"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/btn_outlined_dark"
                    android:text="📋  Paste from Clipboard"
                    android:textAllCaps="false"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnUpdateSecondary"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/btn_outlined_dark"
                    android:text="🔄  Update Secondary URL"
                    android:textAllCaps="false"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ===== CARD 4: Stream Status ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊  Stream Status"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Active status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/statusIndicatorActive"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/status_circle" />

                    <TextView
                        android:id="@+id/tvStatusActive"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Active: Unknown"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Secondary status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/statusIndicatorSecondary"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/status_circle" />

                    <TextView
                        android:id="@+id/tvStatusSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Secondary: Unknown"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressStatus"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="@color/colorAccent"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnCheckActive"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/btn_outlined_dark"
                        android:text="Check Active"
                        android:textAllCaps="false"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnCheckSecondary"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/btn_outlined_dark"
                        android:text="Check Secondary"
                        android:textAllCaps="false"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== CARD 5: YouTube Cache ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📺  YouTube Cache"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvYoutubeCacheInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Tap refresh to check YouTube cache"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/progressYoutube"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="@color/colorAccent"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnRefreshYoutube"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn_red_rounded"
                    android:text="🔄  Force Refresh YouTube"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
